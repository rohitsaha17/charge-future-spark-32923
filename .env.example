# -------- Supabase (public/anon — safe to ship in client bundle) --------
# The publishable key is the `anon` role JWT. RLS is what keeps data safe.
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# -------- Optional: Google Maps --------
# Leave blank to use the bundled MapLibre + Esri tile stack (default).
# VITE_GOOGLE_MAPS_API_KEY=""
